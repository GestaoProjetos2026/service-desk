# Application Configuration
APP_NAME=service-desk
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1

# Database Configuration
# For local development: DB_HOST=localhost
# For Docker Compose: DB_HOST=mysql (service name from docker-compose.yml)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=service_desk
DB_USER=service_user
DB_PASSWORD=service_pass

# MySQL Root Password (used only in docker-compose)
MYSQL_ROOT_PASSWORD=root_pass
