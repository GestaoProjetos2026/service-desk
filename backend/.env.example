# Application
APP_NAME=service-desk
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1

# Database
# Local (sem Docker): DATABASE_URL=postgresql://user:pass@localhost:5432/service_desk
# Docker Compose:     DATABASE_URL=postgresql://service_user:service_pass@postgres:5432/service_desk
# Kubernetes:         DATABASE_URL=postgresql://user_service_desk:SenhaService123!@postgres-svc.infra-banco.svc.cluster.local:5432/infra_banco
DATABASE_URL=postgresql://service_user:service_pass@localhost:5432/service_desk

# ── Integração: Fiscal Finance (Squad 2) ─────────────────────
# URL interna Kubernetes:
FISCAL_FINANCE_URL=http://backend-svc.fiscal-finance.svc.cluster.local:5000
# URL externa para testes locais:
# FISCAL_FINANCE_URL=https://api.fiscal-finance.40.82.176.176.nip.io

# API Key fornecida pelo Squad Fiscal Finance para o Squad Service-Desk
FISC_API_KEY=FISC-PUBLIC-2026-SQUAD4

# Timeout das chamadas inter-squads em segundos
INTEGRATION_TIMEOUT=5.0

# ── Integração: Core Engine (Auth) ───────────────────────────
# URL externa para testes locais:
CORE_ENGINE_URL=http://api.core-engine.40.82.176.176.nip.io
# URL interna Kubernetes (exemplo):
# CORE_ENGINE_URL=http://core-engine-svc.core-engine.svc.cluster.local:8080

# ── CORS ─────────────────────────────────────────────────────
# Origens permitidas pelo backend (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
