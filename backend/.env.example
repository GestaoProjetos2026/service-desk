# Application Configuration
APP_NAME=service-desk
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1

# Database Configuration
# For local development: DB_HOST=localhost
# For Docker Compose: DB_HOST=postgres (service name from docker-compose.yml)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=service_desk
DB_USER=service_user
DB_PASSWORD=service_pass
